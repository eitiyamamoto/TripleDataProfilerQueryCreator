  "optimized_federated_query": "# Smart Federated Query with Class Constraints\n# Note: Multiple class interpretations exist but all route to same endpoints\n# A single query retrieves all data regardless of class ambiguity\n\nSELECT ?methylationCNTNAP2\nWHERE {\n\n  SERVICE <http://localhost:8887/sparql/> {\n    ?recordNo <http://tcga.deri.ie/schema/chromosome> ?chromosome . # ?recordNo:dna_methylation_result, ?chromosome:Literal\n    ?geneId <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://tcga.deri.ie/schema/expression_gene_lookup> .\n    ?recordNo <http://tcga.deri.ie/schema/beta_value> ?methylationCNTNAP2 . # ?recordNo:dna_methylation_result, ?methylationCNTNAP2:Literal\n    ?recordNo <http://tcga.deri.ie/schema/position> ?position . # ?recordNo:dna_methylation_result, ?position:Literal\n  }\n\n  SERVICE <http://localhost:8889/sparql/> {\n    ?uri <http://tcga.deri.ie/schema/bcr_patient_barcode> ?patient . # ?uri:clinical_omf, ?patient:clinical_omf\n    ?patient <http://tcga.deri.ie/schema/result> ?recordNo . # ?patient:clinical_omf, ?recordNo:copy_number_result\n    ?geneId <http://tcga.deri.ie/schema/chromosome> ?lookupChromosome . # ?geneId:copy_number_result, ?lookupChromosome:Literal\n    ?geneId <http://tcga.deri.ie/schema/start> ?start . # ?geneId:copy_number_result, ?start:Literal\n    ?geneId <http://tcga.deri.ie/schema/stop> ?stop . # ?geneId:copy_number_result, ?stop:Literal\n  }\n\n  SERVICE <http://localhost:8899/sparql/> {\n    ?s <http://bio2rdf.org/affymetrix_vocabulary:x-geneid> ?geneId .\n    ?s <http://bio2rdf.org/affymetrix_vocabulary:x-symbol> <http://bio2rdf.org/symbol:CNTNAP2> .\n  }\n}\nLIMIT 1000\n",
