  "optimized_federated_query": "# Smart Federated Query with Class Constraints\n# Note: Multiple class interpretations exist but all route to same endpoints\n# A single query retrieves all data regardless of class ambiguity\n\nSELECT DISTINCT ?artist ?name ?location ?anylocation\nWHERE {\n\n  SERVICE <http://localhost:8891/sparql/> {\n    ?artist <http://xmlns.com/foaf/0.1/name> ?name . # ?artist:Monument, ?name:Literal\n    ?artist <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://purl.org/ontology/mo/MusicArtist> .\n  }\n\n  SERVICE <http://localhost:8897/sparql/> {\n    ?location <http://www.geonames.org/ontology#parentFeature> ?locationName . # ?location:Feature, ?locationName:Feature\n    ?nytLocation <http://www.w3.org/2002/07/owl#sameAs> ?location . # ?nytLocation:Concept, ?location:Feature\n    ?locationName <http://www.geonames.org/ontology#name> ?anylocation . # ?locationName:Feature, ?anylocation:Literal\n    ?locationName <http://www.geonames.org/ontology#name> \"Islamic Republic of Afghanistan\" . # ?locationName:Feature\n    ?nytLocation <http://data.nytimes.com/elements/topicPage> ?news .\n  }\n\n  # Unknown endpoint (no metadata)\n    ?artist <http://xmlns.com/foaf/0.1/based_near> ?location .\n}\nLIMIT 1000\n",
