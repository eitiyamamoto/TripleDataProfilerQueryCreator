  "optimized_federated_query": "# Smart Federated Query with UNION for Multiple Class Interpretations\n# Each UNION branch uses different endpoints or predicates\n\nSELECT ?actor ?actor_name ?actor_name_en ?birthDate ?imdbactor ?movie ?movieDate ?movieTitle ?spouseName ?spouseURI\nWHERE {\n  # Scenario 1: ?movie=film, ?movieDate=Literal, ?movieTitle=Literal, ?imdbactor=Person, ?actor_name_en=Literal, ?actor_name=Literal, ?spouseName=Literal, ?actor=dataset_vocabulary:Endpoint, ?spouseURI=dataset_vocabulary:Endpoint\n  {\n    SERVICE <http://localhost:8896/sparql/> {\n      ?imdbactor <http://data.linkedmdb.org/resource/movie/actor_name> ?actor_name . # ?imdbactor:Person, ?actor_name:Literal\n      ?movie <http://purl.org/dc/terms/date> ?movieDate . # ?movie:film, ?movieDate:Literal\n      ?movie <http://purl.org/dc/terms/title> ?movieTitle . # ?movie:film, ?movieTitle:Literal\n      ?movie <http://data.linkedmdb.org/resource/movie/actor> ?imdbactor . # ?movie:film, ?imdbactor:Person\n    }\n    SERVICE <http://localhost:8899/sparql/> {\n      ?actor <http://www.w3.org/2000/01/rdf-schema#label> ?actor_name_en . # ?actor:dataset_vocabulary:Endpoint, ?actor_name_en:Literal\n      ?spouseURI <http://www.w3.org/2000/01/rdf-schema#label> ?spouseName . # ?spouseURI:dataset_vocabulary:Endpoint, ?spouseName:Literal\n      ?actor <http://dbpedia.org/ontology/spouse> ?spouseURI .\n      ?actor <http://dbpedia.org/ontology/birthDate> ?birthDate .\n    }\n  }\n\n  UNION\n\n  # Scenario 2: ?movie=film, ?movieDate=Literal, ?movieTitle=Literal, ?imdbactor=Person, ?actor_name_en=Literal, ?actor_name=Literal, ?spouseName=Literal, ?actor=dataset_vocabulary:Endpoint, ?spouseURI=film_collection\n  {\n    SERVICE <http://localhost:8896/sparql/> {\n      ?spouseURI <http://www.w3.org/2000/01/rdf-schema#label> ?spouseName . # ?spouseURI:film_collection, ?spouseName:Literal\n      ?imdbactor <http://data.linkedmdb.org/resource/movie/actor_name> ?actor_name . # ?imdbactor:Person, ?actor_name:Literal\n      ?movie <http://purl.org/dc/terms/date> ?movieDate . # ?movie:film, ?movieDate:Literal\n      ?movie <http://purl.org/dc/terms/title> ?movieTitle . # ?movie:film, ?movieTitle:Literal\n      ?movie <http://data.linkedmdb.org/resource/movie/actor> ?imdbactor . # ?movie:film, ?imdbactor:Person\n    }\n    SERVICE <http://localhost:8899/sparql/> {\n      ?actor <http://www.w3.org/2000/01/rdf-schema#label> ?actor_name_en . # ?actor:dataset_vocabulary:Endpoint, ?actor_name_en:Literal\n      ?actor <http://dbpedia.org/ontology/spouse> ?spouseURI .\n      ?actor <http://dbpedia.org/ontology/birthDate> ?birthDate .\n    }\n  }\n\n  UNION\n\n  # Scenario 3: ?movie=film, ?movieDate=Literal, ?movieTitle=Literal, ?imdbactor=Person, ?actor_name_en=Literal, ?actor_name=Literal, ?spouseName=Literal, ?actor=film_collection, ?spouseURI=dataset_vocabulary:Endpoint\n  {\n    SERVICE <http://localhost:8896/sparql/> {\n      ?actor <http://www.w3.org/2000/01/rdf-schema#label> ?actor_name_en . # ?actor:film_collection, ?actor_name_en:Literal\n      ?imdbactor <http://data.linkedmdb.org/resource/movie/actor_name> ?actor_name . # ?imdbactor:Person, ?actor_name:Literal\n      ?movie <http://purl.org/dc/terms/date> ?movieDate . # ?movie:film, ?movieDate:Literal\n      ?movie <http://purl.org/dc/terms/title> ?movieTitle . # ?movie:film, ?movieTitle:Literal\n      ?movie <http://data.linkedmdb.org/resource/movie/actor> ?imdbactor . # ?movie:film, ?imdbactor:Person\n      ?actor <http://dbpedia.org/ontology/spouse> ?spouseURI .\n      ?actor <http://dbpedia.org/ontology/birthDate> ?birthDate .\n    }\n    SERVICE <http://localhost:8899/sparql/> {\n      ?spouseURI <http://www.w3.org/2000/01/rdf-schema#label> ?spouseName . # ?spouseURI:dataset_vocabulary:Endpoint, ?spouseName:Literal\n    }\n  }\n\n  UNION\n\n  # Scenario 4: ?movie=film, ?movieDate=Literal, ?movieTitle=Literal, ?imdbactor=Person, ?actor_name_en=Literal, ?actor_name=Literal, ?spouseName=Literal, ?actor=film_collection, ?spouseURI=film_collection\n  {\n    SERVICE <http://localhost:8896/sparql/> {\n      ?actor <http://www.w3.org/2000/01/rdf-schema#label> ?actor_name_en . # ?actor:film_collection, ?actor_name_en:Literal\n      ?spouseURI <http://www.w3.org/2000/01/rdf-schema#label> ?spouseName . # ?spouseURI:film_collection, ?spouseName:Literal\n      ?imdbactor <http://data.linkedmdb.org/resource/movie/actor_name> ?actor_name . # ?imdbactor:Person, ?actor_name:Literal\n      ?movie <http://purl.org/dc/terms/date> ?movieDate . # ?movie:film, ?movieDate:Literal\n      ?movie <http://purl.org/dc/terms/title> ?movieTitle . # ?movie:film, ?movieTitle:Literal\n      ?movie <http://data.linkedmdb.org/resource/movie/actor> ?imdbactor . # ?movie:film, ?imdbactor:Person\n      ?actor <http://dbpedia.org/ontology/spouse> ?spouseURI .\n      ?actor <http://dbpedia.org/ontology/birthDate> ?birthDate .\n    }\n  }\n}\nLIMIT 1000\n",
