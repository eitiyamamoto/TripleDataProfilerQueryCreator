  "optimized_federated_query": "# Smart Federated Query with Class Constraints\n# Note: Multiple class interpretations exist but all route to same endpoints\n# A single query retrieves all data regardless of class ambiguity\n\nSELECT DISTINCT ?countryName ?countryCode ?locationMap ?population ?longitude ?latitude ?nationalAnthem ?foundingDate ?largestCity ?ethnicGroup ?motto ?NYTplace ?geonameplace. ?geonameplace ?capital ?motto.\nWHERE {\n\n  SERVICE <http://localhost:8891/sparql/> {\n    ?geonameplace <http://dbpedia.org/ontology/motto> ?motto . # ?geonameplace:Country, ?motto:Literal\n    ?geonameplace <http://dbpedia.org/ontology/foundingDate> ?foundingDate . # ?geonameplace:Country, ?foundingDate:Literal\n    ?geonameplace <http://dbpedia.org/ontology/anthem> ?nationalAnthem . # ?geonameplace:Country, ?nationalAnthem:Song\n    ?geonameplace <http://dbpedia.org/ontology/capital> ?capital . # ?geonameplace:Country, ?capital:Country\n    ?geonameplace <http://dbpedia.org/ontology/largestCity> ?largestCity . # ?geonameplace:Country, ?largestCity:Place\n    ?geonameplace <http://dbpedia.org/ontology/ethnicGroup> ?ethnicGroup . # ?geonameplace:Island, ?ethnicGroup:EthnicGroup\n  }\n\n  SERVICE <http://localhost:8897/sparql/> {\n    ?NYTplace <http://www.w3.org/2003/01/geo/wgs84_pos#lat> ?latitude . # ?NYTplace:Feature, ?latitude:Literal\n    ?NYTplace <http://www.w3.org/2003/01/geo/wgs84_pos#long> ?longitude . # ?NYTplace:Feature, ?longitude:Literal\n    ?NYTplace <http://www.geonames.org/ontology#population> ?population . # ?NYTplace:Feature, ?population:Literal\n    ?NYTplace <http://www.w3.org/2002/07/owl#sameAs> ?geonameplace . # ?NYTplace:Concept, ?geonameplace:Feature\n    ?NYTplace <http://www.geonames.org/ontology#countryCode> ?countryCode . # ?NYTplace:Feature, ?countryCode:Literal\n    ?NYTplace <http://www.geonames.org/ontology#name> ?countryName . # ?NYTplace:Feature, ?countryName:Literal\n  }\n}\nLIMIT 1000\n",
